rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to get user's office_id from their user document safely
    function getUserOfficeId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('office_id', '')
        : '';
    }

    // Offices rule: Users belonging to a specific office can read/update their office
    match /offices/{officeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (getUserOfficeId() == officeId || request.resource.data.id == officeId);
      allow delete: if false; // Government offices cannot be deleted arbitrarily
    }

    // Users rule: Allow read to authenticate users in same office; allow write to own profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Subject Classifications: isolated by office_id
    match /subject_classifications/{classId} {
      allow read: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
      allow create, update: if isAuthenticated() && getUserOfficeId() == request.resource.data.office_id;
      allow delete: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
    }

    // Files (নথি): isolated by office_id
    match /files/{fileId} {
      allow read: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
      allow create, update: if isAuthenticated() && getUserOfficeId() == request.resource.data.office_id;
      allow delete: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
    }

    // Recipients: isolated by office_id
    match /recipients/{recipientId} {
      allow read: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
      allow create, update: if isAuthenticated() && getUserOfficeId() == request.resource.data.office_id;
      allow delete: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
    }

    // Officers / Signatories: isolated by office_id
    match /officers/{officerId} {
      allow read: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
      allow create, update: if isAuthenticated() && getUserOfficeId() == request.resource.data.office_id;
      allow delete: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
    }

    // Copy Presets (অনুলিপি): isolated by office_id
    match /copy_presets/{presetId} {
      allow read: if isAuthenticated() && (resource == null || getUserOfficeId() == resource.data.office_id);
      allow create, update: if isAuthenticated() && getUserOfficeId() == request.resource.data.office_id;
      allow delete: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
    }

    // Letters: isolated by office_id
    match /letters/{letterId} {
      allow read: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
      allow create, update: if isAuthenticated() && getUserOfficeId() == request.resource.data.office_id;
      allow delete: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
    }

    // Audit Logs: isolated by office_id
    match /audit_logs/{id} {
      allow read: if isAuthenticated() && getUserOfficeId() == resource.data.office_id;
      allow create: if isAuthenticated() && getUserOfficeId() == request.resource.data.office_id;
      allow update, delete: if false; // Security: audit logs cannot be edited or deleted
    }
  }
}
